{
  "$schema": "./node_modules/turbo/schema.json",
  "concurrency": "4",
  "globalEnv": ["ENVIRONMENT"],
  "tasks": {
    "lint": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "outputs": [],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["build", "test"],
      "env": ["AWS_*", "CARLIN_*"],
      "outputs": [".carlin/**"]
    },
    "release": {
      "dependsOn": ["build"],
      "env": ["NODE_AUTH_TOKEN"],
      "outputs": [],
      "cache": false
    }
  }
}
