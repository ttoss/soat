{
  "$schema": "./node_modules/turbo/schema.json",
  "concurrency": "4",
  "globalEnv": ["ENVIRONMENT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "src/generated/**"]
    },
    "@soat/sdk#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../server/src/rest/openapi/v1/**"],
      "outputs": ["dist/**", "src/generated/**"]
    },
    "@soat/cli#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../server/src/rest/openapi/v1/**"],
      "outputs": ["dist/**", "src/generated/**"]
    },
    "lint": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["build", "test"],
      "env": ["AWS_*", "CARLIN_*"],
      "outputs": [".carlin/**"]
    }
  }
}
