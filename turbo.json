{
  "$schema": "./node_modules/turbo/schema.json",
  "concurrency": "4",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["build", "test"],
      "env": ["AWS_*", "CARLIN_*", "ENVIRONMENT"],
      "outputs": [".carlin/**"]
    },
    "deploy-report": {
      "dependsOn": ["deploy"],
      "outputs": []
    }
  }
}
