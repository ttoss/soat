{
  "private": true,
  "name": "ttoss-soat",
  "version": "1.0.0",
  "license": "MIT",
  "contributors": [
    "Pedro Arantes <arantespp@gmail.com> (https://arantespp.com)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttoss/soat.git"
  },
  "bugs": {
    "url": "https://github.com/ttoss/soat/issues"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "docs-lint": "node scripts/docs-lint.mjs",
    "smoke-tests": "docker compose -f tests/docker-compose.smoke.yml up --build --renew-anon-volumes --remove-orphans --abort-on-container-exit --exit-code-from smoke-test",
    "postsmoke-tests": "docker compose -f tests/docker-compose.smoke.yml down --volumes",
    "tutorials-tests": "docker compose -f tests/docker-compose.tutorials.yml up --build --renew-anon-volumes --remove-orphans --abort-on-container-exit --exit-code-from tutorials",
    "posttutorials-tests": "docker compose -f tests/docker-compose.tutorials.yml down --volumes",
    "syncpack:fix": "syncpack fix",
    "syncpack:lint": "syncpack lint"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@lerna-lite/changed": "^5.4.1",
    "@lerna-lite/cli": "^5.4.1",
    "@lerna-lite/list": "^5.4.1",
    "@lerna-lite/version": "^5.4.1",
    "@ttoss/config": "^1.37.17",
    "@ttoss/eslint-config": "^1.27.0",
    "@ttoss/monorepo": "^1.29.17",
    "carlin": "^1.49.21",
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "turbo": "^2.10.5",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
