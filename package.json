  "scripts": {
    "prepare": "husky",
    "smoke-test": "docker compose -f docker-compose.test.yml up --build --renew-anon-volumes --remove-orphans --abort-on-container-exit --exit-code-from smoke-test",
    "postsmoke-test": "docker compose -f docker-compose.test.yml down --volumes",
