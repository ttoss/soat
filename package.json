    "@ttoss/eslint-config": "^1.26.14",
    "@ttoss/monorepo": "^1.29.8",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "syncpack": "^14.3.0",
    "turbo": "^2.9.4",
    "typescript": "~6.0.2"
