{
  "private": true,
  "name": "@soat/postgresdb",
  "version": "0.15.5",
  "description": "Database models and operations for SOAT packages",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "sync": "ttoss-postgresdb sync"
  },
  "dependencies": {
    "@ttoss/postgresdb": "^0.11.0",
    "nanoid": "^6.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@ttoss/config": "^1.37.17",
    "@ttoss/postgresdb-cli": "^0.2.17",
    "@ttoss/test-utils": "^4.2.18",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.7",
    "typescript": "~6.0.3"
  }
}
