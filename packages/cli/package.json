{
  "name": "@soat/cli",
  "version": "0.15.0",
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "lint": "eslint src tests",
    "test": "jest --config tests/unit/jest.config.ts --coverage=false",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "build": "pnpm generate && tsdown"
  },
  "dependencies": {
    "@inquirer/input": "^5.1.2",
    "@inquirer/password": "^5.1.1",
    "@soat/sdk": "workspace:*",
    "@ttoss/logger": "^0.8.19",
    "commander": "^15.0.0",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@ttoss/config": "^1.37.17",
    "@ttoss/test-utils": "^4.2.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "jest": "^30.4.2",
    "tsdown": "^0.22.3",
    "tsx": "^4.23.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/soat"
  },
  "bin": {
    "soat": "./bin/soat"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
