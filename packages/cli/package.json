{
  "name": "@soat/cli",
  "version": "0.5.5",
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "lint": "eslint src tests",
    "test": "pnpm --filter @soat/sdk build && jest --config tests/unit/jest.config.ts --coverage=false",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "build": "pnpm generate && tsup"
  },
  "dependencies": {
    "@inquirer/input": "^5.0.12",
    "@inquirer/password": "^5.0.12",
    "@soat/sdk": "workspace:*",
    "@ttoss/logger": "^0.8.10",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@ttoss/config": "^1.37.10",
    "@ttoss/test-utils": "^4.2.10",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "jest": "^30.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/soat"
  },
  "bin": {
    "soat": "./bin/soat"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
