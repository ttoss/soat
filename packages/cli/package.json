{
  "name": "@soat/cli",
  "version": "0.8.1",
  "type": "module",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "lint": "eslint src tests",
    "test": "jest --config tests/unit/jest.config.ts --coverage=false",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "build": "pnpm generate && tsdown"
  },
  "dependencies": {
    "@inquirer/input": "^5.1.2",
    "@inquirer/password": "^5.1.1",
    "@soat/sdk": "workspace:*",
    "@ttoss/logger": "^0.8.16",
    "commander": "^15.0.0",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@ttoss/config": "^1.37.15",
    "@ttoss/test-utils": "^4.2.15",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "jest": "^30.4.2",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4"
  },
  "files": [
    "dist",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/soat"
  },
  "bin": {
    "soat": "./bin/soat"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
