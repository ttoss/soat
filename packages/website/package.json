{
  "name": "@soat/website",
  "version": "0.3.4",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "copy-openapi-specs": "node -e \"const fs=require('fs');const path=require('path');const src=path.resolve(__dirname,'../../packages/server/src/rest/openapi/v1');const dest=path.resolve(__dirname,'static/openapi');fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.yaml')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)));console.log('OpenAPI specs copied to static/openapi/')\"",
    "generate-openapi-specs-page": "tsx scripts/generateOpenApiSpecsPage.ts",
    "dev": "pnpm copy-openapi-specs && pnpm generate-openapi-specs-page && docusaurus start",
    "build": "pnpm copy-openapi-specs && pnpm generate-openapi-specs-page && docusaurus gen-api-docs all && pnpm generate-mcp-tools-docs && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "carlin deploy static-app",
    "deploy-report": "carlin deploy report --channel=github-pr",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "gen-api-docs": "docusaurus gen-api-docs all",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "generate-mcp-tools-docs": "tsx scripts/generateMcpToolsDocs.ts"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "^3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.0.0",
    "docusaurus-theme-openapi-docs": "^5.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/js-yaml": "^4.0.9",
    "docusaurus-plugin-llms": "^0.4.0",
    "js-yaml": "^4.1.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
