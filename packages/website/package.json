{
  "name": "@soat/website",
  "version": "0.8.2",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "pnpm generate-all && docusaurus start",
    "build": "pnpm generate-all && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "carlin deploy static-app",
    "deploy-report": "carlin deploy report --channel=github-pr",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "generate-api-docs": "docusaurus gen-api-docs all",
    "generate-all": "pnpm generate-openapi-specs-page && pnpm generate-api-docs && pnpm generate-mcp-tools-docs && pnpm generate-sdk-services-docs && pnpm generate-cli-commands-docs && pnpm generate-permissions-page && pnpm generate-formations-resource-docs",
    "generate-formations-resource-docs": "tsx scripts/generateFormationsResourceDocs.ts",
    "generate-mcp-tools-docs": "tsx scripts/generateMcpToolsDocs.ts",
    "generate-permissions-page": "tsx scripts/generatePermissionsPage.ts",
    "generate-sdk-services-docs": "tsx scripts/generateSdkServicesDocs.ts",
    "generate-cli-commands-docs": "tsx scripts/generateCliCommandsDocs.ts",
    "generate-openapi-specs-page": "tsx scripts/generateOpenApiSpecsPage.ts"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "^5.0.2",
    "docusaurus-theme-openapi-docs": "^5.0.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "camelcase": "^9.0.0",
    "docusaurus-plugin-llms": "^0.4.0",
    "js-yaml": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
