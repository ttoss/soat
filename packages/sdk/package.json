{
  "name": "@soat/sdk",
  "version": "0.15.11",
  "description": "TypeScript SDK for the SOAT API",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm generate && tsdown",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/soat"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@ttoss/config": "^1.37.17",
    "@types/node": "^26.1.1",
    "js-yaml": "^5.2.1",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
