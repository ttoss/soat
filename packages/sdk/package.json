{
  "name": "@soat/sdk",
  "version": "0.6.8",
  "description": "TypeScript SDK for the SOAT API",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm generate && tsdown",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ttoss/soat"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.98.1",
    "@ttoss/config": "^1.37.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "js-yaml": "^4.2.0",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4"
  }
}
