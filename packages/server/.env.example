# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=soat_dev
DATABASE_USER=soat_user
DATABASE_PASSWORD=soat_password

# Server Configuration
PORT=5047
# Required — signs session tokens, OAuth tokens, and file-download tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Public base URL — used for OAuth issuer and to build absolute upload URLs
# SOAT_BASE_URL=https://api.example.com

# Bootstrap admin (optional) — if set and no users exist, an admin is created on startup
SOAT_ADMIN_USERNAME=admin
SOAT_ADMIN_PASSWORD=Admin1234!

# Embedding Configuration
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=1024
OLLAMA_BASE_URL=http://localhost:11434