# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=soat_dev
DATABASE_USER=soat_user
DATABASE_PASSWORD=soat_password

# Server Configuration
PORT=5047
# Required — signs session tokens, OAuth tokens, and file-download tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Public base URL — used for OAuth issuer and to build absolute upload URLs
# SOAT_BASE_URL=https://api.example.com

# Bootstrap admin (optional) — if set and no users exist, an admin is created on startup
SOAT_ADMIN_USERNAME=admin
SOAT_ADMIN_PASSWORD=Admin1234!

# Embedding Configuration
# EMBEDDING_PROVIDER: ollama | openai | bedrock
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=1024
# Ollama only
OLLAMA_BASE_URL=http://localhost:11434
# openai / bedrock only — OpenAI API key or a Bedrock ABSK bearer token.
# openai also falls back to OPENAI_API_KEY. Bedrock without a key uses the
# standard AWS credential chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY).
# EMBEDDING_API_KEY=
# openai only — override the base URL for any OpenAI-compatible endpoint.
# EMBEDDING_BASE_URL=
# bedrock only — AWS region (falls back to AWS_REGION, then us-east-1).
# EMBEDDING_REGION=us-east-1