{
  "name": "@soat/server",
  "version": "0.4.13",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup",
    "db-dev:start": "docker compose -f docker-compose.db.yml up -d",
    "db-dev:stop": "docker compose -f docker-compose.db.yml down",
    "db-dev:rm": "docker compose -f docker-compose.db.yml down -v",
    "db-dev:logs": "docker compose -f docker-compose.db.yml logs -f",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "lint": "pnpm run lint-openapi && eslint src",
    "lint-openapi": "spectral lint src/rest/openapi/**/*.yaml",
    "test": "jest --projects tests/unit"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.100",
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/azure": "^3.0.59",
    "@ai-sdk/google": "^3.0.67",
    "@ai-sdk/groq": "^3.0.38",
    "@ai-sdk/openai": "^3.0.58",
    "@ai-sdk/xai": "^3.0.87",
    "@soat/postgresdb": "workspace:*",
    "@ttoss/http-server": "^0.5.11",
    "@ttoss/http-server-mcp": "^0.12.2",
    "@ttoss/postgresdb": "^0.9.0",
    "ai": "^6.0.174",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "ollama": "^0.6.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.15.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@ttoss/config": "^1.37.10",
    "@ttoss/test-utils": "^4.2.10",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}
