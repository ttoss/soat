{
  "name": "@soat/server",
  "version": "0.15.12",
  "main": "dist/server.mjs",
  "scripts": {
    "build": "tsdown",
    "db-dev:start": "docker compose -f docker-compose.db.yml up -d",
    "db-dev:stop": "docker compose -f docker-compose.db.yml down",
    "db-dev:rm": "docker compose -f docker-compose.db.yml down -v",
    "db-dev:logs": "docker compose -f docker-compose.db.yml logs -f",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "lint": "pnpm run lint-openapi && eslint src",
    "lint-openapi": "spectral lint src/rest/openapi/**/*.yaml",
    "test": "jest --projects tests/unit"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.20",
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/azure": "^4.0.13",
    "@ai-sdk/google": "^4.0.14",
    "@ai-sdk/groq": "^4.0.10",
    "@ai-sdk/openai": "^4.0.13",
    "@ai-sdk/xai": "^4.0.12",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/credential-providers": "^3.1086.0",
    "@soat/postgresdb": "workspace:*",
    "@ttoss/auth-core": "^0.10.0",
    "@ttoss/http-server": "^0.7.1",
    "@ttoss/http-server-auth": "^0.3.7",
    "@ttoss/http-server-mcp": "^0.22.0",
    "@ttoss/postgresdb": "^0.11.0",
    "ai": "^7.0.26",
    "bcryptjs": "^3.0.3",
    "croner": "^10.0.1",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "json-logic-engine": "^5.0.7",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.16.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@ttoss/config": "^1.37.17",
    "@ttoss/test-utils": "^4.2.18",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "supertest": "^7.2.2",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  }
}
