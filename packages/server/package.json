    "dotenv": "^17.4.1",
    "ollama": "^0.6.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@stoplight/spectral-cli": "^6.15.0",
    "@ttoss/config": "^1.37.8",
    "@ttoss/test-utils": "^4.2.8",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
