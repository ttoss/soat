{
  "name": "@soat/server",
  "version": "0.12.1",
  "main": "dist/server.mjs",
  "scripts": {
    "build": "tsdown",
    "db-dev:start": "docker compose -f docker-compose.db.yml up -d",
    "db-dev:stop": "docker compose -f docker-compose.db.yml down",
    "db-dev:rm": "docker compose -f docker-compose.db.yml down -v",
    "db-dev:logs": "docker compose -f docker-compose.db.yml logs -f",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "lint": "pnpm run lint-openapi && eslint src",
    "lint-openapi": "spectral lint src/rest/openapi/**/*.yaml",
    "test": "jest --projects tests/unit"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.112",
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/azure": "^3.0.69",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/xai": "^3.0.93",
    "@soat/postgresdb": "workspace:*",
    "@ttoss/auth-core": "^0.8.0",
    "@ttoss/http-server": "^0.7.1",
    "@ttoss/http-server-auth": "^0.3.5",
    "@ttoss/http-server-mcp": "^0.18.1",
    "@ttoss/postgresdb": "^0.9.6",
    "ai": "^6.0.196",
    "bcryptjs": "^3.0.3",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "json-logic-js": "^2.0.5",
    "jsonwebtoken": "^9.0.3",
    "ollama": "^0.6.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.16.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@ttoss/config": "^1.37.15",
    "@ttoss/test-utils": "^4.2.15",
    "@types/debug": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/json-logic-js": "^2.0.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "js-yaml": "^4.2.0",
    "supertest": "^7.2.2",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4"
  }
}
